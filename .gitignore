# ===================================================================
#  .gitignore for DFD-HR (Python / PyTorch deepfake detection project)
# ===================================================================

# -------------------------------------------------------------------
# 1. Python byte-compiled / cache files
# -------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# -------------------------------------------------------------------
# 2. Python distribution / packaging
# -------------------------------------------------------------------
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# -------------------------------------------------------------------
# 3. Virtual environments
# -------------------------------------------------------------------
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# -------------------------------------------------------------------
# 4. Unit tests / coverage / type-check caches
# -------------------------------------------------------------------
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/

# -------------------------------------------------------------------
# 5. Jupyter Notebook
# -------------------------------------------------------------------
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# -------------------------------------------------------------------
# 6. IDE / editor
# -------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -------------------------------------------------------------------
# 7. Project-specific: large datasets (DO NOT COMMIT, ~11 TB)
# -------------------------------------------------------------------
deepfakes_detection_datasets/
data/
datasets/

# -------------------------------------------------------------------
# 8. Project-specific: training outputs / experiment logs
# -------------------------------------------------------------------
logs/
runs/
outputs/
output/
wandb/
mlruns/

# TensorBoard event files
events.out.tfevents.*
*.tfevents.*

# -------------------------------------------------------------------
# 9. Project-specific: model checkpoints & cached data
# -------------------------------------------------------------------
*.pth
*.pt
*.ckpt
*.bin
*.safetensors
*.onnx
*.h5
*.pkl
*.pickle

# Generated dataset JSON files (per README "Rearrangement" step)
preprocessing/dataset_json/

# -------------------------------------------------------------------
# 10. Misc temp / backup files
# -------------------------------------------------------------------
*.log
*.tmp
*.bak
*.orig
*.rej
nohup.out
core.*
